# API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=cfbdca

# Model ID (required)
MODEL_ID=Doubao-Seed-2.0-pro

# Base URL (optional, for Anthropic-compatible providers)
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding


# Use simulator (true/false)
USE_SIMULATOR=true

# Use LangGraph architecture with Reviewer agent (true/false)
# - true: LangGraph + Reviewer 双臂并行执行 + 自动审查检查
# - false: 传统多线程+消息总线架构
USE_LANGGRAPH=true
